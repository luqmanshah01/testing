
<div
  class="brand-marquee"
  style="
    --marquee-bg: {{ section.settings.background_color }};
    --marquee-color: {{ section.settings.text_color }};
    --marquee-duration: {{ section.settings.speed }}s;
    --marquee-height: {{ section.settings.height }}px;
    --marquee-font-size: {{ section.settings.font_size }}px;
    --marquee-font-weight: {{ section.settings.font_weight }};
    --marquee-letter-spacing: {{ section.settings.letter_spacing | divided_by: 100.0 }}em;
    --marquee-gap: {{ section.settings.item_gap }}px;
    --marquee-logo-height: {{ section.settings.logo_height }}px;
    --marquee-opacity: {{ section.settings.text_opacity | divided_by: 100.0 }};
    --marquee-border: {% if section.settings.show_border %}1px solid rgba(255,255,255,0.1){% else %}none{% endif %};
  "
>
  <div class="brand-marquee__inner">
    <div class="brand-marquee__track{% if section.settings.pause_on_hover %} brand-marquee__track--pause-hover{% endif %}">

      {%- comment -%} First copy {%- endcomment -%}
      <ul class="brand-marquee__list" role="list">
        {%- for block in section.blocks -%}
          <li class="brand-marquee__item" style="--logo-scale: {{ block.settings.logo_width | divided_by: 100.0 }};" {{ block.shopify_attributes }}>
            {%- if block.settings.logo != blank -%}
              {{
                block.settings.logo
                | image_url: width: 400
                | image_tag:
                  class: 'brand-marquee__logo-img',
                  loading: 'lazy',
                  alt: block.settings.name
              }}
            {%- else -%}
              <span class="brand-marquee__logo-text">{{ block.settings.name }}</span>
            {%- endif -%}
          </li>
          {%- unless forloop.last -%}
            <li class="brand-marquee__sep" aria-hidden="true">
              <svg width="6" height="6" viewBox="0 0 6 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="3" cy="3" r="3" fill="currentColor" opacity="0.35"/>
              </svg>
            </li>
          {%- endunless -%}
        {%- endfor -%}
      </ul>

      {%- comment -%} Duplicate for seamless infinite loop {%- endcomment -%}
      <ul class="brand-marquee__list" role="list" aria-hidden="true">
        {%- for block in section.blocks -%}
          <li class="brand-marquee__item" style="--logo-scale: {{ block.settings.logo_width | divided_by: 100.0 }};">
            {%- if block.settings.logo != blank -%}
              {{
                block.settings.logo
                | image_url: width: 400
                | image_tag:
                  class: 'brand-marquee__logo-img',
                  loading: 'lazy',
                  alt: block.settings.name
              }}
            {%- else -%}
              <span class="brand-marquee__logo-text">{{ block.settings.name }}</span>
            {%- endif -%}
          </li>
          {%- unless forloop.last -%}
            <li class="brand-marquee__sep" aria-hidden="true">
              <svg width="6" height="6" viewBox="0 0 6 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="3" cy="3" r="3" fill="currentColor" opacity="0.35"/>
              </svg>
            </li>
          {%- endunless -%}
        {%- endfor -%}
      </ul>

    </div>
  </div>
</div>

{% stylesheet %}
  @keyframes brand-marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .brand-marquee {
    background-color: var(--marquee-bg, #000000);
    color: var(--marquee-color, #ffffff);
    height: var(--marquee-height, 122px);
    overflow: hidden;
    display: flex;
    align-items: center;
    border-top: var(--marquee-border, 1px solid rgba(255,255,255,0.1));
    border-bottom: var(--marquee-border, 1px solid rgba(255,255,255,0.1));
    width: 100%;
  }

  .brand-marquee__inner {
    width: 100%;
    overflow: hidden;
  }

  .brand-marquee__track {
    display: flex;
    width: max-content;
    animation: brand-marquee-scroll var(--marquee-duration, 28s) linear infinite;
  }

  .brand-marquee__track--pause-hover:hover {
    animation-play-state: paused;
  }

  .brand-marquee__list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--marquee-gap, 56px);
    padding-inline: calc(var(--marquee-gap, 56px) / 1);
    flex-shrink: 0;
  }

  .brand-marquee__item {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .brand-marquee__logo-text {
    font-family: 'Satoshi', sans-serif;
    font-weight: var(--marquee-font-weight, 500);
    font-size: var(--marquee-font-size, 16px);
    letter-spacing: var(--marquee-letter-spacing, 0.12em);
    text-transform: uppercase;
    color: var(--marquee-color, #ffffff);
    white-space: nowrap;
    line-height: 1;
    opacity: var(--marquee-opacity, 0.9);
    transition: opacity 0.2s ease;
  }

  .brand-marquee__item:hover .brand-marquee__logo-text {
    opacity: 1;
  }

  .brand-marquee__logo-img {
    height: calc(var(--marquee-logo-height, 32px) * var(--logo-scale, 1));
    width: auto;
    max-width: 180px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: var(--marquee-opacity, 0.85);
    transition: opacity 0.2s ease;
    display: block;
  }

  .brand-marquee__logo-img:hover {
    opacity: 1;
  }

  .brand-marquee__logo-svg {
    display: flex;
    align-items: center;
    height: calc(var(--marquee-logo-height, 32px) * var(--logo-scale, 1));
    opacity: var(--marquee-opacity, 0.85);
    transition: opacity 0.2s ease;
  }

  .brand-marquee__logo-svg:hover {
    opacity: 1;
  }

  .brand-marquee__logo-svg svg {
    height: 100%;
    width: auto;
    display: block;
  }

  .brand-marquee__sep {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: var(--marquee-color, #ffffff);
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-marquee__track {
      animation: none;
    }
    .brand-marquee__list:last-child {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brand Marquee",
  "tag": "section",
  "class": "brand-marquee-section",
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text / logo color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section height (px)",
      "min": 60,
      "max": 200,
      "step": 2,
      "default": 122
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap between items (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show top & bottom border",
      "default": true
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (px)",
      "min": 10,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing (1/100 em)",
      "info": "e.g. 12 = 0.12em",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "text_opacity",
      "label": "Text / logo opacity (%)",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 90
    },
    {
      "type": "header",
      "content": "Logo images"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo image height (px)",
      "min": 16,
      "max": 80,
      "step": 2,
      "default": 32
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds per loop)",
      "info": "Lower = faster",
      "min": 8,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Brand name (shown if no logo uploaded)",
          "default": "Brand"
        },
        {
          "type": "range",
          "id": "logo_width",
          "label": "Logo width (%)",
          "info": "Scale this logo relative to others",
          "min": 50,
          "max": 150,
          "step": 5,
          "default": 100
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Marquee",
      "blocks": [
        { "type": "brand", "settings": { "name": "Versace", "svg_asset": "brand-versace.svg" } },
        { "type": "brand", "settings": { "name": "Zara", "svg_asset": "brand-zara.svg" } },
        { "type": "brand", "settings": { "name": "Gucci", "svg_asset": "brand-gucci.svg" } },
        { "type": "brand", "settings": { "name": "Prada", "svg_asset": "brand-prada.svg" } },
        { "type": "brand", "settings": { "name": "Calvin Klein", "svg_asset": "brand-calvinklein.svg" } }
      ]
    }
  ]
}
{% endschema %}
