
{%- assign current_sort = collection.sort_by | default: collection.default_sort_by -%}
{%- assign section_id = 'fcol-' | append: section.id -%}
{%- assign products_per_page = 9 -%}

{% paginate collection.products by products_per_page %}

<div class="fcol" id="{{ section_id }}">
  <div class="fcol__inner page-width">

    <!-- ── SIDEBAR ── -->
    <aside class="fcol__sidebar">

      <form
        action="{{ collection.url }}"
        method="GET"
        id="fcol-filter-form-{{ section.id }}"
        class="fcol__form"
      >
        <!-- keep sort in filter form -->
        <input type="hidden" name="sort_by" value="{{ current_sort }}">

        <!-- Sidebar header -->
        <div class="fcol__sb-header">
          <span class="fcol__sb-title">Filters</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 5h2M3 12h6M3 19h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="7" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M14 12h7M9 5h12M7 19h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="5" cy="19" r="2" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>

        <!-- Category links (static blocks) -->
        {%- assign cat_blocks = section.blocks | where: 'type', 'nav_category' -%}
        {%- if cat_blocks.size > 0 -%}
          <div class="fcol__cat-list">
            {%- for block in cat_blocks -%}
              <a
                href="{{ block.settings.link | default: collection.url }}"
                class="fcol__cat-link{% if block.settings.link == request.path %} fcol__cat-link--active{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.label }}
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Dynamic Shopify filters -->
        {%- for filter in collection.filters -%}

          {%- if filter.type == 'price_range' -%}
            {%- assign price_min = filter.min_value.value | default: filter.range_min -%}
            {%- assign price_max = filter.max_value.value | default: filter.range_max -%}

            <details class="fcol__filter-group" open>
              <summary class="fcol__filter-head">
                {{ filter.label }}
                <svg class="fcol__filter-caret" width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>

              <div class="fcol__price-wrap" data-price-filter>
                <div class="fcol__price-slider-wrap">
                  <input
                    class="fcol__price-range fcol__price-range--min"
                    type="range"
                    name="{{ filter.min_value.param_name }}"
                    min="{{ filter.range_min | money_without_currency | remove: ',' }}"
                    max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                    value="{{ price_min | money_without_currency | remove: ',' }}"
                    data-price-min
                  >
                  <input
                    class="fcol__price-range fcol__price-range--max"
                    type="range"
                    name="{{ filter.max_value.param_name }}"
                    min="{{ filter.range_min | money_without_currency | remove: ',' }}"
                    max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                    value="{{ price_max | money_without_currency | remove: ',' }}"
                    data-price-max
                  >
                </div>
                <div class="fcol__price-labels">
                  <span data-price-min-label>{{ price_min | money_without_trailing_zeros }}</span>
                  <span data-price-max-label>{{ price_max | money_without_trailing_zeros }}</span>
                </div>
              </div>
            </details>

          {%- elsif filter.type == 'list' -%}

            {%- assign lbl_lower = filter.label | downcase -%}

            <details class="fcol__filter-group" open>
              <summary class="fcol__filter-head">
                {{ filter.label }}
                <svg class="fcol__filter-caret" width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>

              {%- if lbl_lower contains 'color' or lbl_lower contains 'colour' -%}
                <!-- Color swatches -->
                <div class="fcol__colors">
                  {%- for value in filter.values -%}
                    <label
                      class="fcol__color-swatch{% if value.active %} fcol__color-swatch--active{% endif %}"
                      title="{{ value.label }}"
                      style="--swatch-color: {{ value.label | downcase | replace: ' ', '' }};"
                    >
                      <input
                        type="checkbox"
                        name="{{ value.param_name }}"
                        value="{{ value.value }}"
                        {% if value.active %}checked{% endif %}
                        class="fcol__hidden-input"
                      >
                    </label>
                  {%- endfor -%}
                </div>

              {%- elsif lbl_lower contains 'size' -%}
                <!-- Size pills -->
                <div class="fcol__sizes">
                  {%- for value in filter.values -%}
                    <label class="fcol__size-pill{% if value.active %} fcol__size-pill--active{% endif %}">
                      <input
                        type="checkbox"
                        name="{{ value.param_name }}"
                        value="{{ value.value }}"
                        {% if value.active %}checked{% endif %}
                        class="fcol__hidden-input"
                      >
                      {{ value.label }}
                    </label>
                  {%- endfor -%}
                </div>

              {%- else -%}
                <!-- Generic list (e.g. Dress Style) -->
                <ul class="fcol__list">
                  {%- for value in filter.values -%}
                    <li>
                      <label class="fcol__list-item{% if value.active %} fcol__list-item--active{% endif %}">
                        <input
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          class="fcol__hidden-input"
                        >
                        {{ value.label }}
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </label>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            </details>

          {%- endif -%}

        {%- endfor -%}

        <!-- Static color swatches -->
        {%- assign color_blocks = section.blocks | where: 'type', 'color_swatch' -%}
        {%- if color_blocks.size > 0 -%}
          <details class="fcol__filter-group" open>
            <summary class="fcol__filter-head">
              Colors
              <svg class="fcol__filter-caret" width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="fcol__colors">
              {%- for block in color_blocks -%}
                {%- assign is_active = false -%}
                {%- if request.path contains block.settings.tag or current_tags contains block.settings.tag -%}
                  {%- assign is_active = true -%}
                {%- endif -%}
                <a
                  href="{{ collection.url }}?filter.p.tag={{ block.settings.tag }}"
                  class="fcol__color-swatch{% if is_active %} fcol__color-swatch--active{% endif %}"
                  title="{{ block.settings.label }}"
                  style="background-color: {{ block.settings.color }};"
                  {{ block.shopify_attributes }}
                ></a>
              {%- endfor -%}
            </div>
          </details>
        {%- endif -%}

        <!-- Dress Style blocks (static) -->
        {%- assign style_blocks = section.blocks | where: 'type', 'nav_dress_style' -%}
        {%- if style_blocks.size > 0 -%}
          <details class="fcol__filter-group" open>
            <summary class="fcol__filter-head">
              Dress Style
              <svg class="fcol__filter-caret" width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <ul class="fcol__list">
              {%- for block in style_blocks -%}
                <li>
                  <a href="{{ block.settings.link | default: collection.url }}" class="fcol__list-item" {{ block.shopify_attributes }}>
                    {{ block.settings.label }}
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </details>
        {%- endif -%}

        <button type="submit" class="fcol__apply-btn">Apply Filter</button>

      </form>
    </aside>

    <!-- ── MAIN CONTENT ── -->
    <div class="fcol__main">

      <!-- Header row -->
      <div class="fcol__main-header">
        <h1 class="fcol__collection-title">{{ collection.title }}</h1>
        <div class="fcol__main-meta">
          <p class="fcol__count">
            Showing
            {{ paginate.current_offset | plus: 1 }}–{{ paginate.current_offset | plus: collection.products.size }}
            of {{ collection.products_count }} Products
          </p>
          <div class="fcol__sort-wrap">
            <label class="fcol__sort-label" for="fcol-sort-{{ section.id }}">Sort by:</label>
            <div class="fcol__sort-select-wrap">
              <select
                id="fcol-sort-{{ section.id }}"
                class="fcol__sort-select"
                name="sort_by"
                form="fcol-sort-form-{{ section.id }}"
                onchange="document.getElementById('fcol-sort-form-{{ section.id }}').submit()"
              >
                <option value="manual"{% if current_sort == 'manual' %} selected{% endif %}>Featured</option>
                <option value="best-selling"{% if current_sort == 'best-selling' %} selected{% endif %}>Most Popular</option>
                <option value="created-descending"{% if current_sort == 'created-descending' %} selected{% endif %}>Newest Arrivals</option>
                <option value="price-ascending"{% if current_sort == 'price-ascending' %} selected{% endif %}>Price: Low to High</option>
                <option value="price-descending"{% if current_sort == 'price-descending' %} selected{% endif %}>Price: High to Low</option>
              </select>
              <svg class="fcol__sort-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Sort form (separate so sort works without filter) -->
      <form
        id="fcol-sort-form-{{ section.id }}"
        action="{{ collection.url }}"
        method="GET"
        style="display:none;"
      >
        {%- for filter in collection.filters -%}
          {%- if filter.type == 'price_range' -%}
            {%- if filter.min_value.value != null -%}
              <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | remove: ',' }}">
            {%- endif -%}
            {%- if filter.max_value.value != null -%}
              <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | remove: ',' }}">
            {%- endif -%}
          {%- elsif filter.type == 'list' -%}
            {%- for value in filter.active_values -%}
              <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </form>

      <!-- Product Grid -->
      {%- if collection.products.size > 0 -%}
        <div class="fcol__grid">
          {%- for product in collection.products -%}

            {%- assign on_sale = false -%}
            {%- if product.compare_at_price > product.price -%}
              {%- assign on_sale = true -%}
              {%- assign raw_discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
            {%- endif -%}

            <a href="{{ product.url }}" class="fcol__card">

              <div class="fcol__card-img">
                {%- if product.featured_image -%}
                  {{
                    product.featured_image
                    | image_url: width: 533
                    | image_tag:
                      class: 'fcol__img',
                      loading: 'lazy',
                      alt: product.title,
                      widths: '300, 400, 533',
                      sizes: '(min-width: 990px) 30vw, (min-width: 750px) 40vw, 80vw'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'fcol__img fcol__img--ph' }}
                {%- endif -%}
              </div>

              <div class="fcol__card-info">
                <p class="fcol__card-name">{{ product.title }}</p>

                <div class="fcol__card-rating">
                  <div class="fcol__stars" aria-hidden="true">
                    {%- for i in (1..5) -%}
                      <svg class="fcol__star{% if i <= 4 %} fcol__star--on{% endif %}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78z"/>
                      </svg>
                    {%- endfor -%}
                  </div>
                  <span class="fcol__rating-label">4.5/5</span>
                </div>

                <div class="fcol__price-row">
                  {%- if on_sale -%}
                    <span class="fcol__price fcol__price--sale">{{ product.price | money_without_trailing_zeros }}</span>
                    <span class="fcol__price fcol__price--was">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
                    <span class="fcol__badge">-{{ raw_discount }}%</span>
                  {%- else -%}
                    <span class="fcol__price">{{ product.price | money_without_trailing_zeros }}</span>
                  {%- endif -%}
                </div>
              </div>

            </a>

          {%- endfor -%}
        </div>

        <!-- Pagination -->
        {%- if paginate.pages > 1 -%}
          <div class="fcol__pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="fcol__page-btn fcol__page-btn--prev">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Previous
              </a>
            {%- else -%}
              <span class="fcol__page-btn fcol__page-btn--prev fcol__page-btn--disabled">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Previous
              </span>
            {%- endif -%}

            <div class="fcol__page-numbers">
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="fcol__page-num">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="fcol__page-num fcol__page-num--active">{{ part.title }}</span>
                {%- else -%}
                  <span class="fcol__page-num fcol__page-num--ellipsis">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="fcol__page-btn fcol__page-btn--next">
                Next
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- else -%}
              <span class="fcol__page-btn fcol__page-btn--next fcol__page-btn--disabled">
                Next
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}

      {%- else -%}
        <p class="fcol__empty">No products found.</p>
      {%- endif -%}

    </div>
  </div>
</div>

{% endpaginate %}

{% javascript %}
  (function () {
    function initPriceSliders() {
      document.querySelectorAll('[data-price-filter]').forEach(function (wrap) {
        var minInput = wrap.querySelector('[data-price-min]');
        var maxInput = wrap.querySelector('[data-price-max]');
        var minLabel = wrap.querySelector('[data-price-min-label]');
        var maxLabel = wrap.querySelector('[data-price-max-label]');

        function format(v) {
          return '$' + Math.round(v).toLocaleString();
        }

        function update() {
          var min = parseFloat(minInput.value);
          var max = parseFloat(maxInput.value);
          if (min > max) {
            if (this === minInput) { maxInput.value = min; max = min; }
            else { minInput.value = max; min = max; }
          }
          if (minLabel) minLabel.textContent = format(min);
          if (maxLabel) maxLabel.textContent = format(max);

          var pct1 = ((min - minInput.min) / (minInput.max - minInput.min)) * 100;
          var pct2 = ((max - maxInput.min) / (maxInput.max - maxInput.min)) * 100;
          wrap.style.setProperty('--pct-min', pct1 + '%');
          wrap.style.setProperty('--pct-max', pct2 + '%');
        }

        if (minInput && maxInput) {
          minInput.addEventListener('input', update.bind(minInput));
          maxInput.addEventListener('input', update.bind(maxInput));
          update.call(minInput);
        }
      });
    }

    document.readyState === 'loading'
      ? document.addEventListener('DOMContentLoaded', initPriceSliders)
      : initPriceSliders();
  })();
{% endjavascript %}

{% stylesheet %}

  .fcol {
    background: #ffffff;
    padding-block: 2rem 4rem;
  }

  .fcol__inner {
    padding-inline: 1rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media screen and (min-width: 750px) {
    .fcol__inner {
      padding-inline: 2.5rem;
      grid-template-columns: 260px 1fr;
      gap: 2.5rem;
    }
  }

  @media screen and (min-width: 1200px) {
    .fcol__inner {
      padding-inline: 4rem;
      grid-template-columns: 280px 1fr;
    }
  }

  /* ── Sidebar ── */
  .fcol__sidebar {
    background: #ffffff;
  }

  .fcol__form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .fcol__sb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0 1rem;
    border-bottom: 1.5px solid rgba(0,0,0,0.1);
    margin-bottom: 0.5rem;
  }

  .fcol__sb-title {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: #000000;
    line-height: 1;
  }

  /* Category links */
  .fcol__cat-list {
    display: flex;
    flex-direction: column;
    border-bottom: 1.5px solid rgba(0,0,0,0.1);
    padding-block: 0.5rem 0.25rem;
    margin-bottom: 0.25rem;
  }

  .fcol__cat-link {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 0.9375rem;
    color: #666666;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0;
    transition: color 0.2s ease;
  }

  .fcol__cat-link:hover,
  .fcol__cat-link--active {
    color: #000000;
    font-weight: 500;
  }

  /* Filter group accordion */
  .fcol__filter-group {
    border-bottom: 1.5px solid rgba(0,0,0,0.1);
    padding-block: 0.25rem;
  }

  .fcol__filter-head {
    font-family: 'Satoshi', sans-serif;
    font-weight: 600;
    font-size: 0.9375rem;
    color: #000000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    padding: 0.75rem 0;
    list-style: none;
    user-select: none;
  }

  .fcol__filter-head::-webkit-details-marker { display: none; }

  .fcol__filter-group[open] .fcol__filter-caret {
    transform: rotate(180deg);
  }

  .fcol__filter-caret {
    color: #666666;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  /* Hidden checkbox input */
  .fcol__hidden-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  /* ── Price slider ── */
  .fcol__price-wrap {
    padding-bottom: 1rem;
    --pct-min: 0%;
    --pct-max: 100%;
  }

  .fcol__price-slider-wrap {
    position: relative;
    height: 28px;
    display: flex;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .fcol__price-range {
    position: absolute;
    width: 100%;
    height: 4px;
    background: transparent;
    pointer-events: none;
    appearance: none;
    -webkit-appearance: none;
    outline: none;
  }

  .fcol__price-range::-webkit-slider-thumb {
    appearance: none;
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #000000;
    cursor: pointer;
    pointer-events: all;
    border: 3px solid #ffffff;
    box-shadow: 0 0 0 1.5px rgba(0,0,0,0.2);
    position: relative;
    z-index: 2;
  }

  .fcol__price-range::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #000000;
    cursor: pointer;
    pointer-events: all;
    border: 3px solid #ffffff;
    box-shadow: 0 0 0 1.5px rgba(0,0,0,0.2);
  }

  .fcol__price-slider-wrap::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 4px;
    background: #E8E8E8;
    border-radius: 2px;
    z-index: 0;
  }

  .fcol__price-slider-wrap::after {
    content: '';
    position: absolute;
    left: var(--pct-min, 0%);
    right: calc(100% - var(--pct-max, 100%));
    height: 4px;
    background: #000000;
    border-radius: 2px;
    z-index: 1;
    pointer-events: none;
  }

  .fcol__price-labels {
    display: flex;
    justify-content: space-between;
    font-family: 'Satoshi', sans-serif;
    font-size: 0.875rem;
    color: #666666;
  }

  /* ── Colors ── */
  .fcol__colors {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-bottom: 1rem;
  }

  .fcol__color-swatch {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid rgba(0,0,0,0.1);
    transition: border-color 0.2s ease, transform 0.15s ease;
    position: relative;
    display: block;
    background-color: var(--swatch-color, #cccccc);
  }

  /* named color fallbacks */
  .fcol__color-swatch[style*="--swatch-color: green"] { background-color: #4CAF50; }
  .fcol__color-swatch[style*="--swatch-color: red"] { background-color: #F44336; }
  .fcol__color-swatch[style*="--swatch-color: yellow"] { background-color: #FFC633; }
  .fcol__color-swatch[style*="--swatch-color: orange"] { background-color: #FF9800; }
  .fcol__color-swatch[style*="--swatch-color: lightblue"],
  .fcol__color-swatch[style*="--swatch-color: light blue"] { background-color: #87CEEB; }
  .fcol__color-swatch[style*="--swatch-color: blue"] { background-color: #2196F3; }
  .fcol__color-swatch[style*="--swatch-color: purple"] { background-color: #9C27B0; }
  .fcol__color-swatch[style*="--swatch-color: pink"] { background-color: #E91E8C; }
  .fcol__color-swatch[style*="--swatch-color: darkblue"],
  .fcol__color-swatch[style*="--swatch-color: dark blue"],
  .fcol__color-swatch[style*="--swatch-color: navy"] { background-color: #1a237e; }
  .fcol__color-swatch[style*="--swatch-color: black"] { background-color: #000000; }
  .fcol__color-swatch[style*="--swatch-color: white"] { background-color: #ffffff; border-color: rgba(0,0,0,0.2); }
  .fcol__color-swatch[style*="--swatch-color: beige"] { background-color: #F5F0E8; }
  .fcol__color-swatch[style*="--swatch-color: brown"] { background-color: #795548; }
  .fcol__color-swatch[style*="--swatch-color: grey"],
  .fcol__color-swatch[style*="--swatch-color: gray"] { background-color: #9E9E9E; }

  .fcol__color-swatch--active,
  .fcol__color-swatch:hover {
    border-color: #000000;
    transform: scale(1.1);
  }

  /* ── Sizes ── */
  .fcol__sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-bottom: 1rem;
  }

  .fcol__size-pill {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.8125rem;
    font-weight: 400;
    color: #666666;
    background: rgba(0,0,0,0.06);
    border-radius: 62px;
    padding: 0.4rem 0.875rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    user-select: none;
    white-space: nowrap;
  }

  .fcol__size-pill--active,
  .fcol__size-pill:hover {
    background: #000000;
    color: #ffffff;
  }

  /* ── List (dress style, etc.) ── */
  .fcol__list {
    list-style: none;
    margin: 0;
    padding: 0 0 0.75rem;
  }

  .fcol__list-item {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.9375rem;
    font-weight: 400;
    color: #666666;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0;
    cursor: pointer;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .fcol__list-item:hover,
  .fcol__list-item--active {
    color: #000000;
  }

  /* ── Apply button ── */
  .fcol__apply-btn {
    font-family: 'Satoshi', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    color: #ffffff;
    background: #000000;
    border: none;
    border-radius: 62px;
    height: 52px;
    width: 100%;
    cursor: pointer;
    margin-top: 1.5rem;
    transition: background-color 0.2s ease;
  }

  .fcol__apply-btn:hover {
    background: #222222;
  }

  /* ── Main header ── */
  .fcol__main-header {
    margin-bottom: 1.5rem;
  }

  .fcol__collection-title {
    font-family: 'Satoshi', sans-serif;
    font-weight: 900;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: #000000;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    line-height: 1;
  }

  .fcol__main-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .fcol__count {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.875rem;
    color: #666666;
    margin: 0;
    line-height: 1;
  }

  /* Sort dropdown */
  .fcol__sort-wrap {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .fcol__sort-label {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.875rem;
    color: #666666;
    white-space: nowrap;
  }

  .fcol__sort-select-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .fcol__sort-select {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #000000;
    background: transparent;
    border: none;
    padding: 0 1.25rem 0 0;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    outline: none;
  }

  .fcol__sort-caret {
    position: absolute;
    right: 0;
    pointer-events: none;
    color: #666666;
  }

  /* ── Product grid ── */
  .fcol__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media screen and (min-width: 750px) {
    .fcol__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  /* ── Product card ── */
  .fcol__card {
    display: flex;
    flex-direction: column;
    background: #F0EEED;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .fcol__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  }

  .fcol__card-img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .fcol__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .fcol__img--ph { opacity: 0.2; }

  .fcol__card-info {
    padding: 0.5rem 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .fcol__card-name {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    color: #000000;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fcol__card-rating {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .fcol__stars {
    display: flex;
    gap: 1px;
  }

  .fcol__star {
    width: 14px;
    height: 14px;
    fill: #E8E8E8;
    display: block;
  }

  .fcol__star path { fill: inherit; }
  .fcol__star--on { fill: #FFC633; }

  .fcol__rating-label {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.75rem;
    color: #999999;
  }

  .fcol__price-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .fcol__price {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #000000;
  }

  .fcol__price--was {
    font-weight: 400;
    font-size: 0.875rem;
    color: rgba(0,0,0,0.4);
    text-decoration: line-through;
  }

  .fcol__badge {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: #F33F3F;
    background: rgba(243,63,63,0.1);
    border-radius: 62px;
    padding: 0.15rem 0.5rem;
    white-space: nowrap;
  }

  /* ── Pagination ── */
  .fcol__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .fcol__page-btn {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: #000000;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.875rem;
    border: 1.5px solid rgba(0,0,0,0.15);
    border-radius: 62px;
    transition: border-color 0.2s ease, background-color 0.2s ease;
    background: #ffffff;
    cursor: pointer;
  }

  .fcol__page-btn:hover { border-color: #000000; }

  .fcol__page-btn--disabled {
    color: #cccccc;
    pointer-events: none;
    border-color: rgba(0,0,0,0.08);
  }

  .fcol__page-numbers {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .fcol__page-num {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.9375rem;
    font-weight: 400;
    color: #666666;
    text-decoration: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .fcol__page-num:hover { background: rgba(0,0,0,0.06); color: #000000; }

  .fcol__page-num--active {
    background: #000000;
    color: #ffffff;
    font-weight: 600;
  }

  .fcol__page-num--ellipsis { pointer-events: none; }

  /* ── Empty ── */
  .fcol__empty {
    font-family: 'Satoshi', sans-serif;
    font-size: 1rem;
    color: #999999;
    padding: 4rem 0;
    text-align: center;
    margin: 0;
  }

{% endstylesheet %}

