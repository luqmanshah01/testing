
<div class="ds">
  <div class="ds__wrap page-width">
    <div class="ds__container">

      <h2 class="ds__title">{{ section.settings.heading }}</h2>

      <div class="ds__grid">

        <!-- Row 1: narrow (407) left + wide (684) right -->
        <div class="ds__row">
          {%- for block in section.blocks limit: 2 -%}
            <a
              href="{{ block.settings.link | default: routes.collections_url }}"
              class="ds__card {% if forloop.index == 1 %}ds__card--sm{% else %}ds__card--lg{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="ds__label-img">
                {%- if block.settings.label_image != blank -%}
                  {{ block.settings.label_image | image_url: width: 200 | image_tag: class: 'ds__label-img-tag', loading: 'lazy', alt: block.settings.label }}
                {%- else -%}
                  <span class="ds__label-text">{{ block.settings.label }}</span>
                {%- endif -%}
              </div>
              <div class="ds__card-img">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 700
                    | image_tag:
                      class: 'ds__img',
                      loading: 'lazy',
                      alt: block.settings.label,
                      widths: '300, 500, 700',
                      sizes: '(min-width: 750px) 40vw, 80vw'
                  }}
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'ds__img ds__img--ph' }}
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>

        <!-- Row 2: wide (684) left + narrow (407) right -->
        <div class="ds__row">
          {%- for block in section.blocks offset: 2 limit: 2 -%}
            <a
              href="{{ block.settings.link | default: routes.collections_url }}"
              class="ds__card {% if forloop.index == 1 %}ds__card--lg{% else %}ds__card--sm{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="ds__label-img">
                {%- if block.settings.label_image != blank -%}
                  {{ block.settings.label_image | image_url: width: 200 | image_tag: class: 'ds__label-img-tag', loading: 'lazy', alt: block.settings.label }}
                {%- else -%}
                  <span class="ds__label-text">{{ block.settings.label }}</span>
                {%- endif -%}
              </div>
              <div class="ds__card-img">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 700
                    | image_tag:
                      class: 'ds__img',
                      loading: 'lazy',
                      alt: block.settings.label,
                      widths: '300, 500, 700',
                      sizes: '(min-width: 750px) 40vw, 80vw'
                  }}
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'ds__img ds__img--ph' }}
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>

      </div>

    </div>
  </div>
</div>

{% stylesheet %}

  .ds {
    background-color: #ffffff;
    padding-block: 4rem 5rem;
  }

  .ds__wrap {
    padding-inline: 1rem;
  }

  @media screen and (min-width: 750px) {
    .ds__wrap { padding-inline: 2.5rem; }
  }

  @media screen and (min-width: 1200px) {
    .ds__wrap { padding-inline: 4rem; }
  }

  /* ─── Gray rounded outer container ─── */
  .ds__container {
    background-color: #F0EEED;
    border-radius: 20px;
    padding: 3.5rem;
  } 

  @media screen and (max-width: 749px) {
    .ds__container { padding: 1.25rem; }
  }

  /* ─── Heading ─── */
  .ds__title {
    font-family: 'Satoshi', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    text-align: center;
    text-transform: uppercase;
    color: #000000;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin: 0 0 0.5rem;
  }

  /* ─── Two flex rows stacked ─── */
  .ds__grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ds__row {
    display: flex;
    gap: 20px;
    height: 289px;
  }

  /* ─── Card sizes using exact Figma ratios ─── */
  .ds__card--sm {
    flex: 407;
    min-width: 0;
  }

  .ds__card--lg {
    flex: 684;
    min-width: 0;
  }

  /* ─── Card base ─── */
  .ds__card {
    position: relative;
    background-color: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ds__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  /* ─── Label image / text ─── */
  .ds__label-img {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    z-index: 2;
    max-width: 40%;
  }

  .ds__label-img-tag {
    width: auto !important;
    height: auto !important;
    max-width: 100%;
    max-height: 48px;
    display: block;
    object-fit: contain;
  }

  .ds__label-text {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #000000;
    line-height: 1;
  }

  /* ─── Image: right 60%, full height ─── */
  .ds__card-img {
    position: absolute;
    right: 0;
    top: 0;
    width: 60%;
    height: 100%;
    overflow: hidden;
  }

  .ds__img {
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .ds__img--ph {
    opacity: 0.15;
    width: 100%;
    height: 100%;
  }

  /* ─── Mobile: equal 2 columns, shorter height ─── */
  @media screen and (max-width: 749px) {
    .ds__row {
      height: 140px;
    }
    .ds__card--sm,
    .ds__card--lg {
      flex: 1;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Browse By Style",
  "tag": "section",
  "class": "figma-dress-style",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BROWSE BY DRESS STYLE"
    }
  ],
  "blocks": [
    {
      "type": "style",
      "name": "Style Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (fallback text)",
          "default": "Casual"
        },
        {
          "type": "image_picker",
          "id": "label_image",
          "label": "Label image (text logo)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Browse By Style",
      "blocks": [
        { "type": "style", "settings": { "label": "Casual" } },
        { "type": "style", "settings": { "label": "Formal" } },
        { "type": "style", "settings": { "label": "Party" } },
        { "type": "style", "settings": { "label": "Gym" } }
      ]
    }
  ]
}
{% endschema %}
