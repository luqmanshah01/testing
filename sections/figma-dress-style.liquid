
<div class="ds">
  <div class="ds__wrap page-width">

    <h2 class="ds__title">{{ section.settings.heading }}</h2>

    <div class="ds__grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: routes.collections_url }}"
          class="ds__card"
          {{ block.shopify_attributes }}
        >
          <span class="ds__label">{{ block.settings.label }}</span>
          <div class="ds__card-img">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  class: 'ds__img',
                  loading: 'lazy',
                  alt: block.settings.label,
                  widths: '300, 400, 600',
                  sizes: '(min-width: 750px) 33vw, 50vw'
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'ds__img ds__img--ph' }}
            {%- endif -%}
          </div>
        </a>
      {%- else -%}
        {%- assign default_labels = 'Casual,Formal,Party,Gym' | split: ',' -%}
        {%- for label in default_labels -%}
          <div class="ds__card">
            <span class="ds__label">{{ label }}</span>
            <div class="ds__card-img">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'ds__img ds__img--ph' }}
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}

  .ds {
    background-color: #F0EEED;
    padding-block: 4rem 5rem;
  }

  .ds__wrap {
    padding-inline: 1rem;
  }

  @media screen and (min-width: 750px) {
    .ds__wrap { padding-inline: 2.5rem; }
  }

  @media screen and (min-width: 1200px) {
    .ds__wrap { padding-inline: 4rem; }
  }

  .ds__title {
    font-family: 'Satoshi', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    text-align: center;
    text-transform: uppercase;
    color: #000000;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin: 0 0 2rem;
  }

  .ds__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .ds__card {
    position: relative;
    background-color: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    aspect-ratio: 2 / 1.1;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ds__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  .ds__label {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #000000;
    z-index: 2;
    line-height: 1;
  }

  .ds__card-img {
    width: 65%;
    height: 100%;
    flex-shrink: 0;
  }

  .ds__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .ds__img--ph {
    opacity: 0.2;
    width: 100%;
    height: 100%;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Browse By Style",
  "tag": "section",
  "class": "figma-dress-style",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BROWSE BY DRESS STYLE"
    }
  ],
  "blocks": [
    {
      "type": "style",
      "name": "Style Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Casual"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Browse By Style",
      "blocks": [
        { "type": "style", "settings": { "label": "Casual" } },
        { "type": "style", "settings": { "label": "Formal" } },
        { "type": "style", "settings": { "label": "Party" } },
        { "type": "style", "settings": { "label": "Gym" } }
      ]
    }
  ]
}
{% endschema %}
