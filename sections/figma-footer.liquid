
<div class="ff">
  <div class="ff__inner page-width">

    {%- comment -%} ── Newsletter Banner ── {%- endcomment -%}
    <div class="ff__nl">
      <div class="ff__nl-left">
        <h2 class="ff__nl-heading">{{ section.settings.newsletter_heading }}</h2>
      </div>
      <div class="ff__nl-right">
        {%- form 'customer', id: 'figma-footer-newsletter' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="ff__nl-success">Thanks for subscribing!</p>
          {%- else -%}
            <div class="ff__nl-field">
              <span class="ff__nl-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
              <input
                class="ff__nl-input"
                type="email"
                name="contact[email]"
                placeholder="{{ section.settings.email_placeholder }}"
                autocomplete="email"
                required
              >
            </div>
            <button type="submit" class="ff__nl-btn">{{ section.settings.button_label }}</button>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    {%- comment -%} ── Footer Nav Grid ── {%- endcomment -%}
    <div class="ff__nav">

      <div class="ff__brand">
        <p class="ff__logo">{{ section.settings.logo_text }}</p>
        <p class="ff__desc">{{ section.settings.store_description }}</p>
        <div class="ff__social">
          {%- if section.settings.twitter_url != blank -%}
            <a href="{{ section.settings.twitter_url }}" class="ff__social-link" target="_blank" rel="noopener" aria-label="Twitter">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.733-8.834L1.254 2.25H8.08l4.259 5.629L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="ff__social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="ff__social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.github_url != blank -%}
            <a href="{{ section.settings.github_url }}" class="ff__social-link" target="_blank" rel="noopener" aria-label="GitHub">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        <div class="ff__col" {{ block.shopify_attributes }}>
          <h3 class="ff__col-title">{{ block.settings.title }}</h3>
          {%- if block.settings.menu != blank -%}
            <ul class="ff__links">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}" class="ff__link">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}

    </div>

    {%- comment -%} ── Bottom Bar ── {%- endcomment -%}
    <div class="ff__bottom">
      <p class="ff__copy">{{ section.settings.copyright }}</p>
      <div class="ff__payments">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'ff__pay-icon' }}
        {%- endfor -%}
      </div>
    </div>

  </div>
</div>

{% stylesheet %}

  .ff {
    background-color: #ffffff;
    padding-block: 2.5rem 0;
  }

  .ff__inner {
    padding-inline: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media screen and (min-width: 750px) {
    .ff__inner { padding-inline: 2.5rem; }
  }

  @media screen and (min-width: 1200px) {
    .ff__inner { padding-inline: 4rem; }
  }

  /* ── Newsletter Banner ── */
  .ff__nl {
    background-color: #000000;
    border-radius: 20px;
    padding: 2.25rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  @media screen and (max-width: 749px) {
    .ff__nl {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.75rem 1.5rem;
    }
  }

  .ff__nl-left {
    flex: 1;
  }

  .ff__nl-heading {
    font-family: 'Satoshi', sans-serif;
    font-weight: 900;
    font-size: clamp(1.5rem, 2.5vw, 2.125rem);
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
  }

  .ff__nl-right {
    flex: 0 0 380px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media screen and (max-width: 749px) {
    .ff__nl-right {
      flex: unset;
      width: 100%;
    }
  }

  /* Email input row */
  .ff__nl-field {
    position: relative;
    display: flex;
    align-items: center;
  }

  .ff__nl-icon {
    position: absolute;
    left: 1.125rem;
    display: flex;
    align-items: center;
    color: #999999;
    pointer-events: none;
    line-height: 0;
  }

  .ff__nl-input {
    width: 100%;
    height: 52px;
    border-radius: 62px;
    border: none;
    background: #ffffff;
    padding: 0 1.25rem 0 3.25rem;
    font-family: 'Satoshi', sans-serif;
    font-size: 0.9375rem;
    color: #000000;
    outline: none;
  }

  .ff__nl-input::placeholder {
    color: #999999;
  }

  .ff__nl-btn {
    width: 100%;
    height: 52px;
    border-radius: 62px;
    border: none;
    background: #ffffff;
    color: #000000;
    font-family: 'Satoshi', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .ff__nl-btn:hover {
    background-color: #f0f0f0;
  }

  .ff__nl-success {
    color: #ffffff;
    font-family: 'Satoshi', sans-serif;
    font-size: 1rem;
    margin: 0;
  }

  /* ── Footer Nav Grid ── */
  .ff__nav {
    display: grid;
    grid-template-columns: 1.4fr repeat(4, 1fr);
    gap: 2rem;
    padding-block: 2.5rem;
  }

  @media screen and (max-width: 989px) {
    .ff__nav {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ff__nav {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }

  /* Brand column */
  .ff__brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ff__logo {
    font-family: 'Satoshi', sans-serif;
    font-weight: 900;
    font-size: 1.375rem;
    color: #000000;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0;
  }

  .ff__desc {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: #666666;
    line-height: 1.6;
    margin: 0;
    max-width: 220px;
  }

  /* Social icons */
  .ff__social {
    display: flex;
    gap: 0.625rem;
    margin-top: 0.25rem;
  }

  .ff__social-link {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.2);
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000000;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }

  .ff__social-link:hover {
    background-color: #000000;
    border-color: #000000;
    color: #ffffff;
  }

  /* Nav columns */
  .ff__col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ff__col-title {
    font-family: 'Satoshi', sans-serif;
    font-weight: 500;
    font-size: 0.875rem;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    line-height: 1;
  }

  .ff__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .ff__link {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 0.9375rem;
    color: #666666;
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1;
  }

  .ff__link:hover {
    color: #000000;
  }

  /* ── Bottom Bar ── */
  .ff__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    padding-block: 1.5rem 2rem;
    flex-wrap: wrap;
  }

  .ff__copy {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: #666666;
    margin: 0;
    line-height: 1;
  }

  .ff__payments {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .ff__pay-icon {
    height: 28px;
    width: auto;
    border-radius: 4px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    background: #ffffff;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Figma Footer",
  "tag": "section",
  "class": "figma-footer-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Newsletter Banner"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "STAY UPTO DATE ABOUT\nOUR LATEST OFFERS"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe to Newsletter"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "SHOP.CO"
    },
    {
      "type": "textarea",
      "id": "store_description",
      "label": "Store description",
      "default": "We have clothes that suits your style and which you're proud to wear. From women to men."
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter / X URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "github_url",
      "label": "GitHub URL"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "Shop.co © 2000-2023. All Rights Reserved"
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column heading",
          "default": "Company"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Figma Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "title": "COMPANY" } },
        { "type": "menu_column", "settings": { "title": "HELP" } },
        { "type": "menu_column", "settings": { "title": "FAQ" } },
        { "type": "menu_column", "settings": { "title": "RESOURCES" } }
      ]
    }
  ]
}
{% endschema %}
