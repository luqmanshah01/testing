
{%- assign slider_id = 'hc-' | append: section.id -%}

<div class="hc" id="{{ slider_id }}">
  <div class="hc__wrap page-width">

    <div class="hc__header">
      <h2 class="hc__title">{{ section.settings.heading }}</h2>
      <div class="hc__arrows" role="group" aria-label="Scroll reviews">
        <button
          class="hc__arrow hc__arrow--prev"
          aria-label="Previous reviews"
          data-hc-target="{{ slider_id }}"
          data-hc-dir="prev"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M13 16l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          class="hc__arrow hc__arrow--next"
          aria-label="Next reviews"
          data-hc-target="{{ slider_id }}"
          data-hc-dir="next"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="hc__track" data-hc-track>
      {%- for block in section.blocks -%}
        <div class="hc__card" {{ block.shopify_attributes }}>

          <div class="hc__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <svg
                class="hc__star{% if i <= block.settings.rating %} hc__star--on{% endif %}"
                viewBox="0 0 20 20"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78z"/>
              </svg>
            {%- endfor -%}
          </div>

          <div class="hc__reviewer">
            <span class="hc__name">{{ block.settings.name }}</span>
            {%- if block.settings.verified -%}
              <span class="hc__verified" aria-label="Verified buyer">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="10" cy="10" r="10" fill="#01AB31"/>
                  <path d="M6 10l3 3 5-5" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            {%- endif -%}
          </div>

          <p class="hc__text">{{ block.settings.review }}</p>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% javascript %}
  (function () {
    function initSliders() {
      document.querySelectorAll('[data-hc-target]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.getAttribute('data-hc-target');
          var dir = btn.getAttribute('data-hc-dir');
          var section = document.getElementById(id);
          if (!section) return;
          var track = section.querySelector('[data-hc-track]');
          if (!track) return;
          var card = track.querySelector('.hc__card');
          if (!card) return;
          var amount = card.offsetWidth + 20;
          track.scrollBy({ left: dir === 'next' ? amount : -amount, behavior: 'smooth' });
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSliders);
    } else {
      initSliders();
    }
  })();
{% endjavascript %}

{% stylesheet %}

  .hc {
    background-color: #ffffff;
    padding-block: 4rem 5rem;
    overflow: hidden;
  }

  .hc__wrap {
    padding-inline: 1rem;
  }

  @media screen and (min-width: 750px) {
    .hc__wrap { padding-inline: 2.5rem; }
  }

  @media screen and (min-width: 1200px) {
    .hc__wrap { padding-inline: 4rem; }
  }

  /* ─── Header row ─── */
  .hc__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .hc__title {
    font-family: 'Satoshi', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #000000;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
  }

  /* ─── Arrow buttons ─── */
  .hc__arrows {
    display: flex;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  .hc__arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.2);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #000000;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
    padding: 0;
  }

  .hc__arrow:hover {
    background-color: #000000;
    border-color: #000000;
    color: #ffffff;
  }

  .hc__arrow svg {
    display: block;
    flex-shrink: 0;
  }

  /* ─── Scrollable track ─── */
  .hc__track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
    padding-bottom: 6px;
  }

  .hc__track::-webkit-scrollbar {
    display: none;
  }

  /* ─── Card ─── */
  .hc__card {
    flex: 0 0 calc(33.333% - 0.85rem);
    min-width: 260px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 1.75rem;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  @media screen and (max-width: 749px) {
    .hc__card {
      flex: 0 0 82vw;
    }
  }

  /* ─── Stars ─── */
  .hc__stars {
    display: flex;
    gap: 3px;
  }

  .hc__star {
    width: 22px;
    height: 22px;
    fill: #E8E8E8;
    flex-shrink: 0;
    display: block;
  }

  .hc__star path {
    fill: inherit;
  }

  .hc__star--on {
    fill: #FFC633;
  }

  /* ─── Reviewer name + verified badge ─── */
  .hc__reviewer {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .hc__name {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #000000;
    line-height: 1;
  }

  .hc__verified {
    display: flex;
    align-items: center;
    line-height: 0;
    flex-shrink: 0;
  }

  /* ─── Review text ─── */
  .hc__text {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 0.9375rem;
    color: #000000;
    line-height: 1.65;
    margin: 0;
  }

{% endstylesheet %}

{% schema %}
