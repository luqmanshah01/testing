
{%- assign slider_id = 'hc-' | append: section.id -%}

<div class="hc" id="{{ slider_id }}">
  <div class="hc__wrap page-width">

    <div class="hc__header">
      <h2 class="hc__title">{{ section.settings.heading }}</h2>
      <div class="hc__arrows">
        <button
          class="hc__arrow hc__arrow--prev"
          aria-label="Previous reviews"
          data-hc-target="{{ slider_id }}"
          data-hc-dir="prev"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M13 16l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          class="hc__arrow hc__arrow--next"
          aria-label="Next reviews"
          data-hc-target="{{ slider_id }}"
          data-hc-dir="next"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="hc__carousel">

      <div class="hc__track" data-hc-track>
        {%- for block in section.blocks -%}
          <article class="hc__card" {{ block.shopify_attributes }}>

            <div class="hc__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                <svg
                  class="hc__star{% if i <= block.settings.rating %} hc__star--on{% endif %}"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                ><path d="M12 2l2.9 5.87 6.48.94-4.69 4.57 1.11 6.46L12 16.9l-5.8 3.05 1.11-6.46L2.62 8.81l6.48-.94z"/></svg>
              {%- endfor -%}
            </div>

            <div class="hc__reviewer">
              <span class="hc__name">{{ block.settings.name }}</span>
              {%- if block.settings.verified -%}
                <span class="hc__verified" aria-label="Verified buyer">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="10" cy="10" r="10" fill="#01AB31"/>
                    <path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#ffffff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              {%- endif -%}
            </div>

            <p class="hc__text">{{ block.settings.review }}</p>

          </article>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{% javascript %}
  (function () {
    function init() {
      document.querySelectorAll('[data-hc-target]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.getAttribute('data-hc-target');
          var dir = btn.getAttribute('data-hc-dir');
          var wrap = document.getElementById(id);
          if (!wrap) return;
          var track = wrap.querySelector('[data-hc-track]');
          if (!track) return;
          var card = track.querySelector('.hc__card');
          if (!card) return;
          var style = window.getComputedStyle(track);
          var gap = parseFloat(style.gap) || 20;
          track.scrollBy({ left: dir === 'next' ? card.offsetWidth + gap : -(card.offsetWidth + gap), behavior: 'smooth' });
        });
      });
    }
    document.readyState === 'loading'
      ? document.addEventListener('DOMContentLoaded', init)
      : init();
  })();
{% endjavascript %}

{% stylesheet %}

  .hc {
    background-color: #ffffff;
    padding-block: 4rem 5rem;
  }

  .hc__wrap {
    padding-inline: 1rem;
  }

  @media screen and (min-width: 750px) {
    .hc__wrap { padding-inline: 2.5rem; }
  }

  @media screen and (min-width: 1200px) {
    .hc__wrap { padding-inline: 4rem; }
  }

  /* ─── Header row: heading left, arrows right ─── */
  .hc__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  /* ─── Heading ─── */
  .hc__title {
    font-family: 'Satoshi', sans-serif;
    font-weight: 900;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    color: #000000;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.0;
    margin: 0;
  }

  /* ─── Arrow pair top-right ─── */
  .hc__arrows {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .hc__arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.2);
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #000000;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    padding: 0;
    flex-shrink: 0;
  }

  .hc__arrow:hover {
    background-color: #000000;
    border-color: #000000;
    color: #ffffff;
  }

  .hc__arrow svg {
    display: block;
    flex-shrink: 0;
  }

  /* ─── Carousel wrapper ─── */
  .hc__carousel {
    overflow: hidden;
  }

  /* ─── Scrollable track ─── */
  .hc__track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .hc__track::-webkit-scrollbar {
    display: none;
  }

  /* ─── Card — 3 visible + partial 4th ─── */
  .hc__card {
    flex: 0 0 calc((100% - 2 * 1.25rem - 3rem) / 3);
    min-width: 220px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-sizing: border-box;
  }

  @media screen and (max-width: 989px) {
    .hc__card {
      flex: 0 0 calc((100% - 1.25rem - 3rem) / 2);
    }
  }

  @media screen and (max-width: 749px) {
    .hc__card {
      flex: 0 0 82vw;
    }
  }

  /* ─── Stars ─── */
  .hc__stars {
    display: flex;
    gap: 2px;
  }

  .hc__star {
    width: 24px;
    height: 24px;
    fill: #E8E8E8;
    flex-shrink: 0;
    display: block;
  }

  .hc__star path {
    fill: inherit;
  }

  .hc__star--on {
    fill: #FFC633;
  }

  /* ─── Reviewer row ─── */
  .hc__reviewer {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .hc__name {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #000000;
    line-height: 1;
  }

  .hc__verified {
    display: flex;
    align-items: center;
    line-height: 0;
    flex-shrink: 0;
  }

  /* ─── Review text ─── */
  .hc__text {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 0.9375rem;
    color: #000000;
    line-height: 1.65;
    margin: 0;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Happy Customers",
  "tag": "section",
  "class": "figma-happy-customers",
  "disabled_on": { "groups": ["header", "footer"] },
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR HAPPY CUSTOMERS"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
