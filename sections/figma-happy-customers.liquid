  "class": "figma-happy-customers",
  "disabled_on": { "groups": ["header", "footer"] },
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR HAPPY CUSTOMERS"
