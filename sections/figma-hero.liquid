
<div
  class="figma-hero"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="figma-hero__container page-width">

    <div class="figma-hero__main">

      {%- comment -%} LEFT: text content {%- endcomment -%}
      <div class="figma-hero__content">
        {% if section.settings.heading != blank %}
          <h1 class="figma-hero__heading">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="figma-hero__description">{{ section.settings.description }}</p>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_link | default: routes.collections_url }}"
            class="figma-hero__button"
          >
            {{- section.settings.button_label -}}
          </a>
        {% endif %}
      </div>

      {%- comment -%} RIGHT: model image + sparkle stars {%- endcomment -%}
      <div class="figma-hero__media-wrap">

        <span class="figma-hero__sparkle figma-hero__sparkle--large" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M28 2C28 15.8 28 28 28 28C28 28 15.8 28 2 28C15.8 28 28 28 28 28C28 28 28 40.2 28 54C28 40.2 28 28 28 28C28 28 40.2 28 54 28C40.2 28 28 28 28 28C28 28 28 15.8 28 2Z" fill="black"/>
          </svg>
        </span>

        <span class="figma-hero__sparkle figma-hero__sparkle--small" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 1C14 7.9 14 14 14 14C14 14 7.9 14 1 14C7.9 14 14 14 14 14C14 14 14 20.1 14 27C14 20.1 14 14 14 14C14 14 20.1 14 27 14C20.1 14 14 14 14 14C14 14 14 7.9 14 1Z" fill="black"/>
          </svg>
        </span>

        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              class: 'figma-hero__image',
              loading: 'eager',
              fetchpriority: 'high',
              widths: '400, 600, 800',
              sizes: '(min-width: 750px) 45vw, 100vw'
          }}
        {% else %}
          <div class="figma-hero__image-placeholder">
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'figma-hero__placeholder-svg' }}
          </div>
        {% endif %}

      </div>
    </div>

    {%- comment -%} Stats row {%- endcomment -%}
    <div class="figma-hero__stats">

      <div class="figma-hero__stat">
        <span class="figma-hero__stat-number">{{ section.settings.stat_1_number }}</span>
        <span class="figma-hero__stat-label">{{ section.settings.stat_1_label }}</span>
      </div>

      <div class="figma-hero__stat-divider" aria-hidden="true"></div>

      <div class="figma-hero__stat">
        <span class="figma-hero__stat-number">{{ section.settings.stat_2_number }}</span>
        <span class="figma-hero__stat-label">{{ section.settings.stat_2_label }}</span>
      </div>

      <div class="figma-hero__stat-divider" aria-hidden="true"></div>

      <div class="figma-hero__stat">
        <span class="figma-hero__stat-number">{{ section.settings.stat_3_number }}</span>
        <span class="figma-hero__stat-label">{{ section.settings.stat_3_label }}</span>
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  .figma-hero {
    font-family: 'Satoshi', sans-serif;
    overflow: hidden;
    /* Figma: 663px total height at 1440px wide */
    min-height: 400px;
  }

  @media screen and (min-width: 750px) {
    .figma-hero {
      height: 663px;
    }
  }

  .figma-hero__container {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-inline: 1rem;
  }

  @media screen and (min-width: 750px) {
    .figma-hero__container {
      padding-inline: 2.5rem;
    }
  }

  @media screen and (min-width: 1200px) {
    .figma-hero__container {
      padding-inline: 4rem;
    }
  }

  /* ─── Main split layout ─── */
  .figma-hero__main {
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
    min-height: 300px;
  }

  @media screen and (min-width: 750px) {
    .figma-hero__main {
      grid-template-columns: 55% 45%;
      /* grow to fill hero height minus stats row */
      flex: 1;
      min-height: 0;
    }
  }

  /* ─── Left: text ─── */
  .figma-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1.5rem;
    padding-block: 3rem 2rem;
    position: relative;
    z-index: 1;
  }

  @media screen and (min-width: 750px) {
    .figma-hero__content {
      padding-block: 4rem;
      padding-inline-end: 3rem;
      gap: 2rem;
    }
  }

  .figma-hero__heading {
    font-family: 'Satoshi', sans-serif;
    font-weight: 900;
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #000000;
    text-transform: uppercase;
    margin: 0;
  }

  .figma-hero__description {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #666666;
    max-width: 26rem;
    margin: 0;
  }

  .figma-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #000000;
    color: #ffffff;
    font-family: 'Satoshi', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    padding: 0.9rem 2.25rem;
    border-radius: 62px;
    text-decoration: none;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }

  .figma-hero__button:hover {
    background-color: #222222;
    text-decoration: none;
    color: #ffffff;
  }

  /* ─── Right: image + sparkles ─── */
  .figma-hero__media-wrap {
    position: relative;
    display: flex;
    justify-content: flex-end;
    align-items: stretch;
    overflow: hidden;
    min-height: 260px;
    /* let image bleed to right edge on mobile */
    margin-inline-end: -1rem;
  }

  @media screen and (min-width: 750px) {
    .figma-hero__media-wrap {
      align-self: stretch;
      min-height: unset;
      /* restore: image stays within padded container on desktop */
      margin-inline-end: -2.5rem;
    }
  }

  @media screen and (min-width: 1200px) {
    .figma-hero__media-wrap {
      margin-inline-end: -4rem;
    }
  }

  .figma-hero__image {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    /* landscape image: models on right side — crop the empty left space */
    object-fit: cover;
    object-position: 68% bottom;
    position: relative;
    z-index: 1;
  }

  @media screen and (min-width: 750px) {
    .figma-hero__image {
      object-position: 65% bottom;
    }
  }

  .figma-hero__image-placeholder {
    width: 100%;
    max-width: 520px;
    opacity: 0.25;
  }

  .figma-hero__placeholder-svg {
    width: 100%;
    height: auto;
  }

  /* ─── Decorative sparkles ─── */
  .figma-hero__sparkle {
    position: absolute;
    pointer-events: none;
    z-index: 2;
    line-height: 0;
  }

  .figma-hero__sparkle--large {
    top: 8%;
    right: 2%;
  }

  .figma-hero__sparkle--small {
    top: 52%;
    left: 4%;
  }

  @media screen and (min-width: 750px) {
    .figma-hero__sparkle--large {
      top: 12%;
      right: 4%;
    }

    .figma-hero__sparkle--small {
      top: 55%;
      left: 2%;
    }
  }

  /* ─── Stats row ─── */
  .figma-hero__stats {
    display: flex;
    align-items: center;
    border-top: 1.5px solid rgba(0, 0, 0, 0.1);
    padding-block: 2rem 2.5rem;
    gap: 0;
    flex-wrap: wrap;
  }

  @media screen and (min-width: 750px) {
    .figma-hero__stats {
      flex-wrap: nowrap;
      padding-block: 2.5rem 3rem;
    }
  }

  .figma-hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
    min-width: 120px;
    padding-inline: 1.75rem;
  }

  .figma-hero__stat:first-child {
    padding-inline-start: 0;
  }

  .figma-hero__stat-number {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: #000000;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .figma-hero__stat-label {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: #666666;
    line-height: 1.4;
  }

  .figma-hero__stat-divider {
    width: 1.5px;
    height: 56px;
    background-color: rgba(0, 0, 0, 0.12);
    flex-shrink: 0;
    display: none;
  }

  @media screen and (min-width: 750px) {
    .figma-hero__stat-divider {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Figma Hero",
  "tag": "section",
  "class": "figma-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F2F0F1"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FIND CLOTHES THAT MATCHES YOUR STYLE"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Browse through our diverse range of meticulously crafted garments, designed to bring out your individuality and cater to your sense of style."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Model / hero image"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 — number",
      "default": "200+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 — label",
      "default": "International Brands"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 — number",
      "default": "2,000+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 — label",
      "default": "High-Quality Products"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 — number",
      "default": "30,000+"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 — label",
      "default": "Happy Customers"
    }
  ],
  "presets": [
    {
      "name": "Figma Hero"
    }
  ]
}
{% endschema %}
